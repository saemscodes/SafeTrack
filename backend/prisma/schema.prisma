// SafeTrack — Prisma Schema
// PostgreSQL data model for the Personal Safety & Location Tracking App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  username      String   @unique
  phone         String   @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  settings              UserSettings?
  currentLocation       CurrentLocation?
  locationHistory       LocationHistory[]
  contactLinksAsA       ContactLink[]     @relation("LinkA")
  contactLinksAsB       ContactLink[]     @relation("LinkB")
  contactGroupsOwned    ContactGroup[]
  sosEventsTriggered    SosEvent[]        @relation("SOSTrigger")
  sosNotifications      SosNotification[] @relation("SOSNotified")
  trackerTags           TrackerTag[]
  remotePingsIssued     RemotePing[]      @relation("PingIssuer")
  remotePingsTargeted   RemotePing[]      @relation("PingTarget")
  refreshTokens         RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// USER SETTINGS
// ─────────────────────────────────────────
model UserSettings {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ping frequency
  pingMode              PingMode @default(MEDIUM)
  adaptivePingEnabled   Boolean  @default(false)
  customPingIntervalSec Int?     // seconds — overrides preset when set

  // Location sharing
  locationSharingEnabled Boolean @default(true)

  // Data retention (days; null = keep forever)
  retentionDays         Int?     @default(30)

  // SOS settings
  sosMode               SosMode  @default(SILENT_ALERT)
  sosGroupId            String?  // default group for SOS notifications

  updatedAt             DateTime @updatedAt

  @@map("user_settings")
}

enum PingMode {
  HIGH    // 30s interval
  MEDIUM  // 5min interval
  LOW     // 15min interval
  CUSTOM
}

enum SosMode {
  SILENT_ALERT
  // Future modes: AUDIBLE_ALARM, AUTO_CALL, etc.
}

// ─────────────────────────────────────────
// CONTACTS & GROUPS
// ─────────────────────────────────────────
model ContactLink {
  id        String          @id @default(uuid())
  userAId   String
  userBId   String
  userA     User            @relation("LinkA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User            @relation("LinkB", fields: [userBId], references: [id], onDelete: Cascade)
  status    ContactStatus   @default(PENDING)
  initiatedBy String        // userId who sent the request
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userAId, userBId])
  @@map("contact_links")
}

enum ContactStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model ContactGroup {
  id        String               @id @default(uuid())
  ownerId   String
  owner     User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime             @default(now())
  members   ContactGroupMember[]

  @@map("contact_groups")
}

model ContactGroupMember {
  id            String       @id @default(uuid())
  groupId       String
  group         ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  linkedUserId  String       // must be a mutually-accepted contact of the group owner

  @@unique([groupId, linkedUserId])
  @@map("contact_group_members")
}

// ─────────────────────────────────────────
// LOCATION
// ─────────────────────────────────────────
model CurrentLocation {
  id          String         @id @default(uuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat         Float
  lng         Float
  accuracy    Float?         // metres
  altitude    Float?
  speed       Float?
  bearing     Float?
  batteryPct  Int?
  source      LocationSource
  trackerTagId String?       // set when source = BLE_TRACKER_TAG
  updatedAt   DateTime       @updatedAt

  @@map("current_locations")
}

model LocationHistory {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat          Float
  lng          Float
  accuracy     Float?
  altitude     Float?
  speed        Float?
  bearing      Float?
  batteryPct   Int?
  source       LocationSource
  pingMechanism PingMechanism? // which mechanism produced this (preset/adaptive/custom)
  trackerTagId  String?         // set when source = BLE_TRACKER_TAG
  recordedAt   DateTime
  createdAt    DateTime        @default(now())

  @@index([userId, recordedAt(sort: Desc)])
  @@map("location_history")
}

enum LocationSource {
  NATIVE_GPS
  SMS_FALLBACK
  BLE_TRACKER_TAG
  REMOTE_PING_FORCED
  CLOUD_FAILSAFE_LAST_KNOWN
  BLE_TRACKER_INDEPENDENT
}

enum PingMechanism {
  PRESET
  ADAPTIVE
  CUSTOM
  MANUAL
}

// ─────────────────────────────────────────
// SOS EVENTS
// ─────────────────────────────────────────
model SosEvent {
  id              String            @id @default(uuid())
  triggeredById   String
  triggeredBy     User              @relation("SOSTrigger", fields: [triggeredById], references: [id])
  mode            SosMode
  lat             Float
  lng             Float
  accuracy        Float?
  groupId         String?           // contact group notified
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  notifications   SosNotification[]

  @@map("sos_events")
}

model SosNotification {
  id          String              @id @default(uuid())
  sosEventId  String
  sosEvent    SosEvent            @relation(fields: [sosEventId], references: [id], onDelete: Cascade)
  notifiedId  String
  notified    User                @relation("SOSNotified", fields: [notifiedId], references: [id])
  status      SosAckStatus        @default(SENT)
  pushedAt    DateTime?
  seenAt      DateTime?
  ackAt       DateTime?
  ackMessage  String?             // e.g. "On my way"
  createdAt   DateTime            @default(now())

  @@map("sos_notifications")
}

enum SosAckStatus {
  SENT
  DELIVERED
  SEEN
  ON_MY_WAY
  ACKNOWLEDGED
}

// ─────────────────────────────────────────
// BLE TRACKER TAGS
// ─────────────────────────────────────────
model TrackerTag {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String
  bleUuid         String   // BLE MAC or UUID
  batteryPct      Int?
  lastSeenLat     Float?
  lastSeenLng     Float?
  lastSeenAt      DateTime?
  lastSeenAddress String?  // reverse-geocoded friendly address
  isActive        Boolean  @default(true)
  pairedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, bleUuid])
  @@map("tracker_tags")
}

// ─────────────────────────────────────────
// REMOTE PING REQUESTS
// ─────────────────────────────────────────
model RemotePing {
  id          String      @id @default(uuid())
  issuerId    String
  issuer      User        @relation("PingIssuer", fields: [issuerId], references: [id])
  targetId    String
  target      User        @relation("PingTarget", fields: [targetId], references: [id])
  status      PingStatus  @default(QUEUED)
  queuedAt    DateTime    @default(now())
  deliveredAt DateTime?
  respondedAt DateTime?
  responseLat Float?
  responseLng Float?

  @@map("remote_pings")
}

enum PingStatus {
  QUEUED
  DELIVERED
  RESPONDED
  FAILED
  EXPIRED
}
